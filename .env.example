# Copy to .env and fill in to enable LLM-powered planning & SQL self-repair.
# Without a key, the platform runs fully offline using the deterministic planner
# (graceful degradation) — every demo, test and eval still passes.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# ADP_MODEL=claude-sonnet-4-6
# ADP_DB_PATH=data/warehouse.duckdb
# ADP_MAX_RETRIES=3
# ADP_LOG_LEVEL=INFO
